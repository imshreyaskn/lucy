{
  "manifest_version": 3,
  "name": "Lucy",
  "version": "1.0.0",
  "description": "Browse the internet entirely by voice. Built for accessibility.",
  "icons": {
    "128": "public/icon.png"
  },
  "permissions": [
    "sidePanel", "tabs", "storage", "scripting",
    "activeTab", "webNavigation", "commands"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "src/background/background.ts", "type": "module" },
  "side_panel": { "default_path": "src/sidepanel/index.html" },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "action": { 
    "default_title": "Lucy",
    "default_icon": "public/icon.png"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["src/content/content.ts"],
    "run_at": "document_idle"
  }],
  "commands": {
    "toggle-listening": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Push-to-talk: hold to speak"
    }
  }
}
